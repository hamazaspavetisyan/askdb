LISTENING_PORT=3000

# Which LLM backend the query agent uses: "anthropic" (default) or "openai".
LLM_PROVIDER=anthropic

# --- Anthropic (used when LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...
#ANTHROPIC_MODEL=claude-sonnet-4-6

# --- OpenAI (used when LLM_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ============================================================
# MCP server (npm run start:mcp) — read-only DB access over HTTP.
# Only needed if you expose the database to MCP clients (Claude, Cursor, ...).
# The target connection is fixed here (it is NOT taken from the web UI).
# ============================================================
# MCP_PORT=3001
# MCP_AUTH_TOKEN=change-me-long-random      # clients send: Authorization: Bearer <token>
# DB_TYPE=mongodb
# DB_HOST=localhost
# DB_PORT=27017
# DB_USER=root
# DB_PASS=...
# DB_AUTH_SOURCE=admin
# Optional SSH tunnel for the MCP connection:
# SSH_HOST=46.4.13.102
# SSH_PORT=22
# SSH_USER=sky
# SSH_PRIVATE_KEY_PATH=/Users/you/.ssh/mykey      # or SSH_PRIVATE_KEY="-----BEGIN ..."
# SSH_PASSPHRASE=
